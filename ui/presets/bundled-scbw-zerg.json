{
  "volume": 3,
  "randomPreset": true,
  "mappings": [
    {
      "name": "welcome",
      "triggers": [
        {
          "type": "event",
          "event": "SessionStart"
        }
      ],
      "sounds": [
        "scbw-zerg/drone-rdy00.wav"
      ]
    },
    {
      "name": "acknowledge",
      "triggers": [
        {
          "type": "event",
          "event": "UserPromptSubmit"
        }
      ],
      "sounds": [
        "scbw-zerg/drone-yes00.wav",
        "scbw-zerg/drone-yes01.wav",
        "scbw-zerg/drone-yes02.wav",
        "scbw-zerg/drone-yes03.wav"
      ]
    },
    {
      "name": "work-complete",
      "triggers": [
        {
          "type": "event",
          "event": "Stop"
        }
      ],
      "sounds": [
        "scbw-zerg/advisor-upd00.wav"
      ]
    },
    {
      "name": "permission-asked",
      "triggers": [
        {
          "type": "event",
          "event": "Notification"
        }
      ],
      "sounds": [
        "scbw-zerg/drone-pss00.wav"
      ]
    },
    {
      "name": "working-hard",
      "whisper": true,
      "triggers": [
        {
          "type": "tool.before",
          "tool": "todowrite"
        },
        {
          "type": "tool.before",
          "tool": "todoread"
        },
        {
          "type": "tool.before",
          "tool": "read"
        },
        {
          "type": "tool.before",
          "tool": "write"
        },
        {
          "type": "tool.before",
          "tool": "edit"
        },
        {
          "type": "tool.before",
          "tool": "glob"
        },
        {
          "type": "tool.before",
          "tool": "grep"
        },
        {
          "type": "tool.before",
          "tool": "bash"
        }
      ],
      "sounds": [
        "scbw-zerg/drone-wht00.wav",
        "scbw-zerg/drone-wht01.wav",
        "scbw-zerg/drone-wht02.wav"
      ]
    }
  ]
}
