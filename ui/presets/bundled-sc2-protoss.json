{
  "volume": 3,
  "randomPreset": true,
  "mappings": [
    {
      "name": "welcome",
      "triggers": [
        {
          "type": "event",
          "event": "SessionStart"
        }
      ],
      "sounds": [
        "sc2-protoss/zealot-ready00.mp3"
      ]
    },
    {
      "name": "acknowledge",
      "triggers": [
        {
          "type": "event",
          "event": "UserPromptSubmit"
        }
      ],
      "sounds": [
        "sc2-protoss/zealot-yes00.mp3",
        "sc2-protoss/zealot-yes01.mp3",
        "sc2-protoss/zealot-yes02.mp3",
        "sc2-protoss/zealot-yes03.mp3",
        "sc2-protoss/zealot-yes04.mp3"
      ]
    },
    {
      "name": "work-complete",
      "triggers": [
        {
          "type": "event",
          "event": "Stop"
        }
      ],
      "sounds": [
        "sc2-protoss/alert-protossresearchcomplete.mp3"
      ]
    },
    {
      "name": "permission-asked",
      "triggers": [
        {
          "type": "event",
          "event": "Notification"
        }
      ],
      "sounds": [
        "sc2-protoss/alert-protossupgradecomplete.mp3"
      ]
    },
    {
      "name": "working-hard",
      "whisper": true,
      "triggers": [
        {
          "type": "tool.before",
          "tool": "todowrite"
        },
        {
          "type": "tool.before",
          "tool": "todoread"
        },
        {
          "type": "tool.before",
          "tool": "read"
        },
        {
          "type": "tool.before",
          "tool": "write"
        },
        {
          "type": "tool.before",
          "tool": "edit"
        },
        {
          "type": "tool.before",
          "tool": "glob"
        },
        {
          "type": "tool.before",
          "tool": "grep"
        },
        {
          "type": "tool.before",
          "tool": "bash"
        }
      ],
      "sounds": [
        "sc2-protoss/zealot-what00.mp3",
        "sc2-protoss/zealot-what01.mp3",
        "sc2-protoss/zealot-what02.mp3"
      ]
    }
  ]
}
